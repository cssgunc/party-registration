{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "paths": {
      "@/*": ["./../src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "playwright/test"]
  },
  "include": ["./**/*.ts", "../playwright.config.ts"]
}
