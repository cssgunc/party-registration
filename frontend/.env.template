# Dev environment only. For production, see deploy/.env.prod.template.

# ── App ───────────────────────────────────────────────────────────────────────

# Base URL of the backend API. Keep as-is for local dev container.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
API_BASE_URL=http://localhost:8000/api

# Search radius (in miles) used for the police proximity map. Optional (check env.client.ts for defaults)
# NEXT_PUBLIC_PARTY_SEARCH_RADIUS_MILES=

# ── Internal API ──────────────────────────────────────────────────────────────

# Shared secret for authenticating internal service-to-service calls between
# the frontend and backend. Must match INTERNAL_API_SECRET in backend/.env.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=REPLACE_ME

# ── Authentication (NextAuth) ─────────────────────────────────────────────────

# Secret used to sign NextAuth session tokens. Use any long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=REPLACE_ME

# Base URL of the Next.js app. Keep as-is for local dev container.
NEXTAUTH_URL=http://localhost:3000

# ── SAML / SSO ────────────────────────────────────────────────────────────────

# Entity ID of this app as a SAML Service Provider. Keep as-is for local dev.
SAML_SP_ENTITY_ID=next-auth-client

# Endpoint the IdP posts SAML assertions to. Keep as-is for local dev.
SAML_ASSERT_ENDPOINT=http://localhost:3000/api/auth/login/saml

# SSO login URL of the Identity Provider.
SAML_IDP_SSO_LOGIN_URL=http://localhost:8080/simplesaml/saml2/idp/SSOService.php

# SSO logout URL of the Identity Provider.
SAML_IDP_SSO_LOGOUT_URL=http://localhost:8080/simplesaml/saml2/idp/SingleLogoutService.php

# Public certificate of the IdP used to verify SAML responses.
# The value below is the test cert from kristophjunge/test-saml-idp and is safe for local dev.
SAML_IDP_

# Allow unencrypted SAML assertions. Set to true for local dev with the test IdP.
SAML_ALLOW_UNENCRYPTED_ASSERTION=true

# ── Google Maps ───────────────────────────────────────────────────────────────

# Google Maps API key used for the embedded map and address autocomplete.
# Should match GOOGLE_MAPS_API_KEY in backend/.env.
# Required APIs: Maps JavaScript API, Places API
# Obtain at: https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=REPLACE_ME

# Google Maps Map ID required for Advanced Markers on the embedded map.
# Create one at: https://console.cloud.google.com → Google Maps Platform → Map Management
NEXT_PUBLIC_GOOGLE_MAP_ID=REPLACE_ME

# ── Police / CHPD ─────────────────────────────────────────────────────────────

# Email domain used to identify Chapel Hill Police Department accounts. Optional (check env.client.ts for defaults)
# NEXT_PUBLIC_CHPD_EMAIL_DOMAIN=

# Cooldown in seconds before a police verification email can be resent. Optional (check env.client.ts for defaults)
# NEXT_PUBLIC_POLICE_VERIFICATION_RESEND_COOLDOWN_SECONDS=
