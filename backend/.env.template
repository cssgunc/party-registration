# Dev environment only. For production, see deploy/.env.prod.template.

# ── Database (devcontainer SQL Server) ───────────────────────────────────────
MSSQL_HOST=db
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong!Passw0rd
MSSQL_TRUST_SERVER_CERTIFICATE=yes

# Optional — see src/core/config.py for defaults
# MSSQL_DATABASE=
# MSSQL_PORT=
# MSSQL_DRIVER=

# ── Frontend URL (used for CORS) ──────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000

# ── Email (devcontainer Mailpit) ──────────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_TLS=false

# Optional — see src/core/config.py for defaults
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# ── JWT ───────────────────────────────────────────────────────────────────────

# Secret key used to sign JWT access tokens. Use any long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_ME

# Secret key used to sign JWT refresh tokens. Use a different value from JWT_SECRET_KEY.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
REFRESH_TOKEN_SECRET_KEY=REPLACE_ME

# Optional — see src/core/config.py for defaults
# JWT_ALGORITHM=
# ACCESS_TOKEN_EXPIRE_MINUTES=
# REFRESH_TOKEN_EXPIRE_DAYS=

# ── Internal API ──────────────────────────────────────────────────────────────

# Secret used to authenticate internal service-to-service API calls. Use any long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# This should match the value of INTERNAL_API_SECRET in the frontend .env.local file
INTERNAL_API_SECRET=REPLACE_ME

# ── Google Maps ───────────────────────────────────────────────────────────────

# Google Maps API key used for address autocomplete and place detail lookups.
# Obtain the existing key from the team or create a new one at: https://console.cloud.google.com → APIs & Services → Credentials
# Required APIs: Places API
# Note: the frontend uses the same key — set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY in frontend/.env.local to the same value
GOOGLE_MAPS_API_KEY=REPLACE_ME

# ── App config ────────────────────────────────────────────────────────────────

# Optional — see src/core/config.py for defaults
# PARTY_SEARCH_RADIUS_MILES=
# CHPD_EMAIL_DOMAIN=
# EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=

# ── Logging ───────────────────────────────────────────────────────────────────
# Log all SQL queries to stdout. Useful for dev, should be off in prod.
SQLALCHEMY_ECHO=true
