# Copy this file to .env.prod and fill in all values before deploying.
# .env.prod is gitignored and should never be committed.
# Optional vars are commented out — see backend/src/core/config.py and
# frontend/src/lib/config/env.client.ts for their defaults.

# ── Database (MySQL) ──────────────────────────────────────────────────────────
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=

# Optional
# MYSQL_PORT=
# MYSQL_DATABASE=

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public-facing URL of the frontend (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://partysmart.unc.edu/api
API_BASE_URL=https://partysmart.unc.edu/api
NEXTAUTH_URL=https://partysmart.unc.edu
FRONTEND_BASE_URL=https://partysmart.unc.edu

# ── Auth secrets (generate with: `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET_KEY=
REFRESH_TOKEN_SECRET_KEY=
INTERNAL_API_SECRET=
NEXTAUTH_SECRET=

# ── SAML (UNC SSO) ────────────────────────────────────────────────────────────
# Before deploying, generate SP certs once and place them in deploy/certs/:
#   mkdir -p deploy/certs
#   openssl req -x509 -newkey rsa:2048 -keyout deploy/certs/key.pem -out deploy/certs/cert.pem -days 3650 -nodes
# Give cert.pem to the UNC IdP admin to register this app as a Service Provider.
# The certs are bind-mounted into the container - never regenerate them unless you re-register with the IdP.
SAML_SP_ENTITY_ID=https://partysmart.unc.edu
SAML_ASSERT_ENDPOINT=https://partysmart.unc.edu/api/auth/login/saml
SAML_IDP_SSO_LOGIN_URL=
SAML_IDP_SSO_LOGOUT_URL=
SAML_IDP_CERT=
SAML_ALLOW_UNENCRYPTED_ASSERTION=false

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true

# Optional
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAP_ID=

# ── App config (all optional) ─────────────────────────────────────────────────
# NEXT_PUBLIC_POLICE_VERIFICATION_RESEND_COOLDOWN_SECONDS=
# NEXT_PUBLIC_CHPD_EMAIL_DOMAIN=
# NEXT_PUBLIC_PARTY_SEARCH_RADIUS_MILES=

# ── Logging (all optional) ────────────────────────────────────────────────────
# SQLALCHEMY_ECHO= (defaults to false - do not enable in prod)
